{
  "manifest_version": 3,
  "name": "WFH Browser Tracker",
  "version": "1.1",
  "description": "Tracks active browser tabs for WFH monitoring.",

  "permissions": [
    "tabs",
    "activeTab",
    "storage"
  ],

  "host_permissions": [
    "<all_urls>"
  ],

  "background": {
    "service_worker": "background.js"
  },

  "action": {
    "default_popup": "popup.html",
    "default_title": "WFH Tracker"
  }
}
